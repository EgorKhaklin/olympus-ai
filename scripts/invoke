#!/usr/bin/env python3
"""invoke — thin wrapper around olympus.cli:main.

This file lets you call `./scripts/invoke <errand>` without installing the
package. For a pip-installed Olympus, the `invoke` console script defined
in pyproject.toml does the same thing.
"""
from __future__ import annotations

import pathlib
import sys

HERE = pathlib.Path(__file__).resolve().parent
ROOT = HERE.parent
SRC = ROOT / "src"
if str(SRC) not in sys.path:
    sys.path.insert(0, str(SRC))

from olympus.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
